# Stripe Sandbox credentials
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Webhook secret (from Stripe CLI: stripe listen --print-secret)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe Dashboard login (for GUI tests)
STRIPE_DASHBOARD_EMAIL=your@email.com
STRIPE_DASHBOARD_PASSWORD=your_password_here

# Test configuration
PAYMENT_AMOUNT=2000
PAYMENT_CURRENCY=usd
